# ──────────────────────────────────────────────────────────────
# Configurazione progetto Meteo Dashboard
# Copia questo file in `.env` e inserisci i valori reali.
# Il file `.env` NON viene versionato in git.
# ──────────────────────────────────────────────────────────────

# --- Database (MariaDB) ---
MYSQL_ROOT_PASSWORD=cambia_questa_password_root
MYSQL_DATABASE=meteo
MYSQL_USER=meteo
MYSQL_PASSWORD=cambia_questa_password

# Host/porta usati dai container per raggiungere il DB
DB_HOST=db
DB_PORT=3306

# Porta esposta sull'host per la dashboard web
WEB_PORT=8080

# --- API MeteoNetwork (https://api.meteonetwork.it) ---
# Credenziali usate per rigenerare il token quando scade
METEONETWORK_MAIL=tua_email@example.com
METEONETWORK_PASSWORD=la_tua_password
# Token iniziale (verra' rinnovato automaticamente al primo 401)
METEONETWORK_TOKEN=

# Stazioni MeteoNetwork da monitorare (codici separati da virgola).
# La prima e' la stazione "principale" (default in dashboard).
#   STAZIONE1 = Padova - Centro
#   STAZIONE2 = Palestro - Montecengio
#   STAZIONE3 = Padova - Montà
STATION_CODES=STAZIONE1,STAZIONE2,STAZIONE3

# --- Schedulazione collector ---
# Realtime ogni N minuti (allineato all'orologio), daily una volta al giorno.
REALTIME_INTERVAL_MIN=15
DAILY_HOUR=9
# Esegue un primo recupero realtime all'avvio del container
RUN_AT_START=true

# Timezone dei container
TZ=Europe/Rome
